# Entity: coffee

main: kit: entity: coffee: {

  alias: field: {}

  fields: [
    {
      name: "description"
      req: false
      type: "`$STRING`"
    }
    {
      name: "id"
      req: false
      type: "`$INTEGER`"
    }
    {
      name: "image"
      req: true
      type: "`$STRING`"
    }
    {
      name: "ingredient"
      req: true
      type: "`$ARRAY`"
    }
    {
      name: "title"
      req: true
      type: "`$STRING`"
    }
  ]

  id: {
    field: "id"
    name: "id"
  }

  name: "coffee"
  op: {
    list: {
      name: "list"
      points: [
        {
          method: "GET"
          orig: "/api/coffees"
          parts: [
            "api"
            "coffees"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
    update: {
      name: "update"
      points: [
        {
          method: "PUT"
          orig: "/api/coffees"
          parts: [
            "api"
            "coffees"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}

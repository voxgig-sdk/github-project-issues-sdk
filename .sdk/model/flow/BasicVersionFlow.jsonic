# BasicVersionFlow

main: kit: flow: BasicVersionFlow:
{
  entity: "version",
  kind: "basic",
  name: "BasicVersionFlow",
  step: [
    {
      input: {
        ref: "version_ref01",
        srcdatavar: "version_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-version_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicVersionFlow"
}